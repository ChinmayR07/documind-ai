# ─── Copy this to .env and fill in your values ────────────────────────────────
# NEVER commit .env to git — it's in .gitignore

# ─── Claude AI ────────────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Local Redis (when running with Docker Compose)
REDIS_URL=redis://localhost:6379
# For production (Upstash Redis):
# REDIS_URL=rediss://your-upstash-url

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── File Upload Settings ─────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20          # Maximum upload file size in MB
UPLOAD_DIR=uploads           # Local directory to store uploaded files

# ─── Claude Model Settings ────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_TIMEOUT_SECONDS=60

# ─── Cache Settings ───────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600       # How long to cache results (1 hour)
CACHE_ENABLED=true
